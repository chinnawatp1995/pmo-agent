# ===========================================
# Knowledge Module Configuration
# ===========================================

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=lightrag
POSTGRES_PASSWORD=lightrag_password
POSTGRES_DB=lightrag_db

# FalkorDB Configuration (Graph Storage)
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
FALKORDB_PASSWORD=
FALKORDB_DB=0

# LLM Configuration (Fireworks AI)
FIREWORKS_API_KEY=
LLM_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
LLM_BASE_URL=https://api.fireworks.ai/inference/v1
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.7

# Embedding Configuration
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_BASE_URL=https://api.fireworks.ai/inference/v1
EMBEDDING_DIMENSION=768
EMBEDDING_BATCH_SIZE=100

# LightRAG Configuration
LIGHTRAG_WORKING_DIR=./rag_storage
LIGHTRAG_WORKSPACE=default
LIGHTRAG_KV_STORAGE=PGKVStorage
LIGHTRAG_VECTOR_STORAGE=PGVectorStorage
LIGHTRAG_GRAPH_STORAGE=PGGraphStorage
LIGHTRAG_DOC_STATUS_STORAGE=PGDocStatusStorage
LIGHTRAG_DEFAULT_QUERY_MODE=hybrid
LIGHTRAG_DEFAULT_TOP_K=60

# OpenAI (Alternative - uncomment if using OpenAI)
# OPENAI_API_KEY=sk-xxx
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536
